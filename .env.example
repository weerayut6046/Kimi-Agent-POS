# ── Shared server secrets ───────────────────────────────────────
APP_ID=pumppos
APP_SECRET=replace-with-at-least-32-random-bytes
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://kimi-agent-pos.vercel.app

# ── Local/Docker database ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@session-pooler-host:5432/postgres
DIRECT_URL=postgresql://user:password@session-pooler-host:5432/postgres
DATABASE_POOL_SIZE=5      # จำนวน connection สูงสุดต่อ backend instance
DATABASE_IDLE_TIMEOUT_SECONDS=300 # รักษา connection ให้อุ่น ลดเวลารอหลังระบบว่าง

# Supabase Edge Functions มี SUPABASE_URL, SUPABASE_ANON_KEY,
# SUPABASE_SERVICE_ROLE_KEY และ SUPABASE_DB_URL ให้ใน runtime อยู่แล้ว
# ห้ามนำ service role หรือ database URL ไปใส่ใน VITE_* หรือ client
SUPABASE_PROJECT_REF=lexjxdrypkwqnlpjkttd

# Frontend/Vite ใช้ได้เฉพาะ publishable values
VITE_SUPABASE_URL=https://lexjxdrypkwqnlpjkttd.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key
VITE_SUPABASE_FUNCTION_REGION=ap-northeast-1

# ── AI assistant ───────────────────────────────────────────────
# Provider, Model และ DeepSeek API Key ตั้งจาก ตั้งค่าระบบ > AI (admin)
# ค่าด้านล่างเป็นค่าเชื่อมต่อ Ollama ของเครื่อง server เท่านั้น
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_MS=180000
# Emergency fallback สำหรับผู้ดูแล infrastructure (ปกติไม่ต้องตั้ง):
# AI_ASSISTANT_PROVIDER=ollama
# OLLAMA_MODEL=qwen3:4b-instruct
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash

# ── Optional self-hosted backup (ไม่ใช้ใน Supabase Edge) ────────────────
# Production cloud ใช้ Supabase Managed Backups ส่วนค่านี้เก็บไว้สำหรับ
# Docker/self-hosted เท่านั้น
GCS_BACKUP_PROJECT_ID=kimi-agent-pos
GCS_BACKUP_BUCKET=        # private bucket; ห้ามใช้ bucket สาธารณะของตัวอัปเดต
GCS_BACKUP_CREDENTIALS_BASE64= # service-account JSON ที่เข้ารหัส base64
# เปิดเฉพาะเมื่อ bucket มี Soft Delete และ service account มี storage.objects.delete
GCS_BACKUP_DELETE_ENABLED=false
BACKUP_CRON_SECRET=       # random secret สำหรับ scheduler ของระบบ self-hosted
# PG_DUMP_PATH=pg_dump
# PG_RESTORE_PATH=pg_restore

# ── Docker Compose (ใช้โดย docker-compose.yml — ตั้งค่าใน .env ได้) ─────────
# APP_PORT=3000
# SEED_ON_START=false
