# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # path ไฟล์ SQLite (default: ./data/pos.db, Docker: /data/pos.db)

# ── Docker Compose (ใช้โดย docker-compose.yml — ตั้งค่าใน .env ได้) ─────────
# APP_PORT=3000
# SEED_ON_START=true
