# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@session-pooler-host:5432/postgres"
DIRECT_URL="postgresql://user:password@session-pooler-host:5432/postgres"
DATABASE_POOL_SIZE=5      # จำนวน connection สูงสุดต่อ backend instance
DATABASE_IDLE_TIMEOUT_SECONDS=300 # รักษา connection ให้อุ่น ลดเวลารอหลังระบบว่าง

# ── Off-site database backup (Private Google Cloud Storage) ───────────────
SUPABASE_PROJECT_REF=lexjxdrypkwqnlpjkttd
GCS_BACKUP_PROJECT_ID=kimi-agent-pos
GCS_BACKUP_BUCKET=        # private bucket; ห้ามใช้ bucket สาธารณะของตัวอัปเดต
GCS_BACKUP_CREDENTIALS_BASE64= # service-account JSON ที่เข้ารหัส base64
BACKUP_CRON_SECRET=       # random secret สำหรับ Google Cloud Scheduler → Railway
# PG_DUMP_PATH=pg_dump
# PG_RESTORE_PATH=pg_restore

# ── Docker Compose (ใช้โดย docker-compose.yml — ตั้งค่าใน .env ได้) ─────────
# APP_PORT=3000
# SEED_ON_START=false
