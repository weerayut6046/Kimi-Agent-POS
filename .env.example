# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@session-pooler-host:5432/postgres"
DIRECT_URL="postgresql://user:password@session-pooler-host:5432/postgres"
DATABASE_POOL_SIZE=5      # จำนวน connection สูงสุดต่อ backend instance

# ── Docker Compose (ใช้โดย docker-compose.yml — ตั้งค่าใน .env ได้) ─────────
# APP_PORT=3000
# SEED_ON_START=false
